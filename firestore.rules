rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only owner can read/write their own doc
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Passengers: owner writes, any authenticated user reads (drivers need heatmap data)
    match /passengers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Drivers: owner writes, any authenticated user reads (passengers need ETA data)
    match /drivers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Routes: readable by all auth'd users; only backend service account writes
    match /routes/{routeId} {
      allow read: if request.auth != null;
      allow write: if false; // backend only via Admin SDK
    }

    // Stops (aggregated demand): readable by all auth'd; backend writes
    match /stops/{stopId} {
      allow read: if request.auth != null;
      allow write: if false; // backend only
    }

    // Cooperatives: readable by dispatcher/admin roles only
    match /cooperatives/{coopId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
